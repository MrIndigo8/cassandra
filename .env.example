# ============================================================
# Кассандра — Шаблон переменных окружения
# Скопируй как .env.local и заполни значения
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Anthropic (Claude API) ---
ANTHROPIC_API_KEY=

# --- Новостные API ---
NEWSAPI_KEY=
GDELT_API_URL=https://api.gdeltproject.org/api/v2

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry ---
SENTRY_DSN=

# --- PostHog ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# --- Cron / фоновые вызовы (тот же секрет в Vercel + при ручном вызове API) ---
CRON_SECRET=

# --- Антиспам (POST /api/entries): макс. записей на пользователя за 24ч (по умолчанию 20) ---
# ANTISPAM_MAX_ENTRIES_PER_24H=20

# --- Приложение ---
# Для локальной разработки: http://localhost:3000
# Для продакшена (Vercel): https://<your-project>.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Кассандра

# На Vercel задаётся автоматически; для локальных проверок cron можно не задавать
# VERCEL_URL=
